# Email (SMTP) — opcional. Sem essas variáveis, os lembretes serão simulados.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@odontoflow.app

# Exemplo com Gmail (App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx

# Exemplo com Resend SMTP:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
